# Copy to .env and adjust. Every value has a working local default; the API
# boots and the full index -> chat flow runs with NO changes (offline mock
# providers + in-memory vector store fallback).

# --- Database ---
DATABASE_URL=postgresql+psycopg://osae:osae@localhost:5432/osae

# --- Vector store ---
QDRANT_URL=http://localhost:6333

# --- Providers (BYO key). mock | openai | ollama ---
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock

# OpenAI (or any OpenAI-compatible endpoint)
# LLM_PROVIDER=openai
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (fully local)
# LLM_PROVIDER=ollama
# EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=llama3.1
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
