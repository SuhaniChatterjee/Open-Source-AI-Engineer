# Copy to .env and adjust. Every value has a working local default; the API
# boots and the full index -> chat flow runs with NO changes (offline mock
# providers + in-memory vector store fallback).

# --- Database ---
DATABASE_URL=postgresql+psycopg://osae:osae@localhost:5432/osae

# --- Vector store ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=            # required by Qdrant Cloud

# --- Production only (see DEPLOYMENT.md) --------------------------------
# The app REFUSES TO BOOT with ENVIRONMENT=production unless these are set.
# ENVIRONMENT=production
# ALLOW_DEV_LOGIN=false      # dev-login = passwordless login as ANY user
# SESSION_SECRET=            # long random string (never the shipped default)
# ENCRYPTION_KEY=            # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_SAMESITE=none   # needed when frontend/API are on different sites
# CORS_ORIGINS=https://your-app.vercel.app
# FRONTEND_URL=https://your-app.vercel.app
# GITHUB_CLIENT_ID=          # OAuth App — the only way to sign in in prod
# GITHUB_CLIENT_SECRET=
# TASK_BACKEND=celery
# CELERY_TASK_ALWAYS_EAGER=false
# GITHUB_TOKEN=              # optional: raises GitHub API limits 60/hr -> 5000/hr

# --- Providers (BYO key). mock | gemini | openai | ollama ---
# "mock" is an OFFLINE FALLBACK: it lists matching files instead of explaining
# them. Use gemini/openai for real synthesized answers. Providers are normally
# chosen per-user in Settings; these are server-level defaults/fallbacks.
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock

# Gemini — free tier covers both chat and embeddings (aistudio.google.com/apikey)
# LLM_PROVIDER=gemini
# EMBEDDING_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# OpenAI (or any OpenAI-compatible endpoint)
# LLM_PROVIDER=openai
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (fully local)
# LLM_PROVIDER=ollama
# EMBEDDING_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=llama3.1
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
